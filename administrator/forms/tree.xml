<?xml version="1.0" encoding="utf-8"?>
<form>
	<fieldset name="details">
		<field
			name="id"
			type="hidden"
		/>

		<field
			name="title"
			type="text"
			label="COM_DECISIONTREE_FIELD_TITLE_LABEL"
			required="true"
			maxlength="255"
		/>

		<field
			name="alias"
			type="text"
			label="COM_DECISIONTREE_FIELD_ALIAS_LABEL"
			hint="JFIELD_ALIAS_PLACEHOLDER"
			maxlength="400"
		/>

		<field
			name="description"
			type="textarea"
			label="COM_DECISIONTREE_FIELD_DESCRIPTION_LABEL"
			rows="5"
			filter="safehtml"
		/>

		<field
			name="state"
			type="list"
			label="JSTATUS"
			default="1"
			validate="options"
			>
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
			<option value="-2">JTRASHED</option>
		</field>

		<field
			name="json_data"
			type="textarea"
			label="COM_DECISIONTREE_FIELD_JSON_DATA_LABEL"
			rows="18"
			filter="raw"
		/>
	</fieldset>
</form>
